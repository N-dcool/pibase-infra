# — PiBase – Portainer Stack Environment Variables ————
# Add these in Portainer UI when deploying pibase-api stack.
# This file is for reference only – do NOT commit actual values.

# DockerHub username (used to pull the image)
DOCKERHUB_USERNAME=your-dockerhub-username

# JWT signing secret – must be at least 256 bits (32+ chars)
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=CHANGE_ME

# CORS – origins allowed to call the API
ALLOWED_ORIGINS=https://db.nareshchoudhary.com

# TCP hostname - used in directUri for database coonections
# This must resolve to VPS reply IP (DNS-only / grey cloud in Cloudflare)
TCP_HOST=tcp.nareshchoudhary.com 